<!DOCTYPE html PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN" "http://www.w3.org/TR/html4/loose.dtd">
<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>[[ subject or 'Notificación' ]]</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f4f4; font-family:Arial,Helvetica,sans-serif;">

<table border="0" cellpadding="0" cellspacing="0" width="100%"
       style="background-color:#f4f4f4; padding:24px 0;">
  <tr>
    <td align="center" valign="top">
      <table border="0" cellpadding="0" cellspacing="0" width="600"
             style="background-color:#ffffff; border-radius:6px; overflow:hidden;
                    box-shadow:0 2px 8px rgba(0,0,0,0.08);">

        [% if logo_url %]
        <!-- Logo superior via URL — compatible con todos los clientes de correo incluyendo Outlook -->
        <tr>
          <td align="center" style="padding:24px 32px 8px; background-color:#ffffff;">
            <img src="[[ logo_url ]]"
                 alt="[[ tenant_name or '' ]]"
                 style="max-height:72px; max-width:260px; display:block; border:0; outline:0;" />
          </td>
        </tr>
        [% elif logo_base64 %]
        <!-- Logo superior embebido base64 — funciona en Gmail/webmail, bloqueado por Outlook por defecto -->
        <tr>
          <td align="center" style="padding:24px 32px 8px; background-color:#ffffff;">
            <img src="[[ logo_base64 ]]"
                 alt="[[ tenant_name or '' ]]"
                 style="max-height:72px; max-width:260px; display:block; border:0; outline:0;" />
          </td>
        </tr>
        [% endif %]

        [% if logo_bottom_url %]
        <!-- Logo inferior via URL -->
        <tr>
          <td align="center" style="padding:0px 32px 24px; background-color:#ffffff;">
            <img src="[[ logo_bottom_url ]]"
                 alt="[[ tenant_name or '' ]]"
                 style="max-height:64px; max-width:240px; display:block; border:0; outline:0;" />
          </td>
        </tr>
        [% elif logo_bottom_base64 %]
        <!-- Logo inferior embebido base64 -->
        <tr>
          <td align="center" style="padding:0px 32px 24px; background-color:#ffffff;">
            <img src="[[ logo_bottom_base64 ]]"
                 alt="[[ tenant_name or '' ]]"
                 style="max-height:64px; max-width:240px; display:block; border:0; outline:0;" />
          </td>
        </tr>
        [% endif %]

        <!-- Barra de acento con color primario del tema -->
        <tr>
          <td height="4"
              style="background-color:[[ theme.primary_color ]]; font-size:0; line-height:0; mso-line-height-rule:exactly;">
            &nbsp;
          </td>
        </tr>

        <!-- Contenido principal -->
        <tr>
          <td style="padding:32px; font-size:15px; line-height:1.65; color:#333333;
                     font-family:Arial,Helvetica,sans-serif;">
            [[ body_html ]]
          </td>
        </tr>

        [% if cta_url %]
        <!-- Botón CTA -->
        <tr>
          <td align="center" style="padding:0 32px 24px;">
            <table border="0" cellpadding="0" cellspacing="0">
              <tr>
                <td align="center"
                    style="background-color:[[ theme.primary_color ]]; border-radius:6px; mso-padding-alt:0;">
                  <a href="[[ cta_url ]]"
                     target="_blank"
                     style="display:inline-block; padding:12px 28px;
                            font-family:Arial,Helvetica,sans-serif;
                            font-size:14px; font-weight:bold; color:#ffffff;
                            text-decoration:none; border-radius:6px;
                            background-color:[[ theme.primary_color ]];">
                    Acceder
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        [% endif %]

        <!-- Separador -->
        <tr>
          <td style="height:1px; background-color:#eeeeee; font-size:0; line-height:0;">&nbsp;</td>
        </tr>

        <!-- Footer -->
        <tr>
          <td align="center"
              style="padding:16px 32px; background-color:#f9f9f9;
                     font-family:Arial,Helvetica,sans-serif;">
            <p style="font-size:11px; color:#888888; margin:0; line-height:1.5;">
              [[ theme.email_footer_text or '' ]]
            </p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>

</body>
</html>
