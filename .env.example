# ------------------------------------------------------------------------------
# AUTHENTIK LOGIN MANAGER - ENVIRONMENT CONFIGURATION
# ------------------------------------------------------------------------------

# Database (PostgreSQL) Configuration
POSTGRES_DB=authentik_login_manager
POSTGRES_USER=admin
POSTGRES_PASSWORD=casmarts_secure_db_pwd_2026
POSTGRES_HOST=casmarts-core-pgpool
POSTGRES_PORT=5432

# Async Database Connection URL
DATABASE_URL=postgresql+asyncpg://admin:casmarts_secure_db_pwd_2026@casmarts-core-pgpool:5432/authentik_login_manager

# Cache Connection URL (Valkey)
VALKEY_URL=redis://casmarts-core-cache:6379/0

# Security (Administrative API Auth)
ADMIN_API_KEY=casmarts_admin_super_secret_key_123

# API Gateway & Client CORS Origins (Comma separated URLs)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# URL pública del backend, usada al generar URLs absolutas de imágenes en el HTML desplegado a Authentik
# Debe ser accesible desde el navegador del usuario final (no un hostname interno de Docker)
PUBLIC_API_BASE_URL=https://login-manager.casmarts.internal

# Frontend Environment Variables (Replicated in React bundle)
VITE_API_BASE_URL=https://loginmanager.casmart.internal
VITE_ADMIN_KEY=casmarts_admin_super_secret_key_123
