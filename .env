# Database (PostgreSQL) Configuration
POSTGRES_DB=authentik_login_manager
POSTGRES_USER=admin
POSTGRES_PASSWORD=casmarts_secure_db_pwd_2026
POSTGRES_HOST=casmarts-core-db-primary
POSTGRES_PORT=5432

# Async Database Connection URL
DATABASE_URL=postgresql+asyncpg://admin:casmarts_secure_db_pwd_2026@casmarts-core-db-primary:5432/authentik_login_manager

# Cache Connection URL (Valkey)
VALKEY_URL=redis://casmarts-core-cache:6379/0

# Security (Administrative API Auth)
ADMIN_API_KEY=casmarts_admin_super_secret_key_123

# API Gateway & Client CORS Origins (Comma separated URLs)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://auth.casmart.internal,https://loginmanager.casmart.internal

# URL pública del backend (usada en plantillas de correo para imágenes - compatible con Outlook)
PUBLIC_API_BASE_URL=https://loginmanager.casmart.internal

# SMTP para envío de correos de prueba desde el panel de administración
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=arquitecturacasmarts@gmail.com
SMTP_PASSWORD=zxyfmbycyjaezajh
SMTP_FROM=arquitecturacasmarts@gmail.com
SMTP_TLS=true

# Frontend Environment Variables (Replicated in React bundle)
VITE_API_BASE_URL=https://loginmanager.casmart.internal
VITE_ADMIN_KEY=casmarts_admin_super_secret_key_123
